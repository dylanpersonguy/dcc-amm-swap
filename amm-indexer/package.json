  },
  "dependencies": {
    "@dcc-amm/core": "1.0.0",
    "@dcc-amm/sdk": "1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^20.0.0"
  },
  "license": "MIT"
}
